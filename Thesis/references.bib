@article{30,
    title = {Examining the {Effects} on a {Fatigue} {Life} of {Preloaded} {Bolts} in {Flange} {Joints}: {An} {Overview}},
    volume = {14},
    shorttitle = {Examining the {Effects} on a {Fatigue} {Life} of {Preloaded} {Bolts} in {Flange} {Joints}},
    doi = {10.3390/met14080883},
    abstract = {The amplitude of a bolt load in dynamically loaded bolted flange joints depends on several factors: the resilience of the bolt and the clamping parts, the magnitude of the working load, the point of action of the working load, the way the working load is transferred from the structure to the bolt, the preload, and the geometrical imperfections of the contact surfaces of the joint. These factors are analysed in many papers, and they are covered in the VDI 2230 guideline and in standards. Fatigue curves (S-N curves) of bolts are determined by tests in which an ideal axial load is usually applied to the bolts. The effects of the bolt strength class, the thread manufacturing process, the surface protection, and the cross-section size on the fatigue strength of bolts are precisely defined. The main problem in the evaluation of bolted joints is the calculation of the actual stress, which is compared with the fatigue curves. Despite extensive research, fatigue-related bolt failures still occur in practise. This article provides a systematic overview of the influences that affect the fatigue of bolts. The conclusions are based on the research results of many authors and on our own analytical, numerical, and experimental investigations. The effects are illustrated using two practical examples of flange bolting. The assessment of fatigue according to Eurocode 3 and the VDI 2230 guideline is discussed in more detail.},
    journal = {Metals},
    author = {Okorn, Ivan and Nagode, Marko and Klemenc, Jernej and Oman, Simon},
    month = jul,
    year = {2024},
    pages = {883},
}
@article{45,
    title = {Experimental evaluation of different spectral methods for damage estimation of an electrical panel bracket mounted on a military wheeled vehicle},
    volume = {35},
    issn = {1976-3824},
    url = {https://doi.org/10.1007/s12206-021-1127-6},
    doi = {10.1007/s12206-021-1127-6},
    abstract = {This study evaluates different frequency domain vibration fatigue methods by verifying the results of the analyses with the experimental data on the bracket of an electrical panel mounted on a military vehicle. Loadings are defined considering composite wheeled vehicle vibration exposure as stated in the MIL-STD-810G Standard. The electrical panel and the bracket are simulated by FEM. Response PSDs are created on critical points. The experiment is carried out by using a uniaxial electrodynamic shaker. In this study, the Dirlik method proposes the most reliable and accurate fatigue life, while the Wirsching-Light method overestimates. Ortiz-Chen has made a very conservative prediction among other methods in this case study.},
    language = {en},
    number = {12},
    urldate = {2026-02-03},
    journal = {Journal of Mechanical Science and Technology},
    author = {Gümüş, Mehmet Sefa and Erdemir, Abdullah and Alver, Veysel and Kalyoncu, Mete},
    month = dec,
    year = {2021},
    keywords = {Dirlik, Frequency domain fatigue, Tovo-benasciutti, Vibration fatigue, Wirsching-light},
    pages = {5561--5569},
}
@article{48,
    title = {Fatigue failure analysis and life prediction of micro-pipelines under heterogeneous random vibration loads in aerospace engines},
    volume = {216},
    issn = {02638231},
    url = {https://linkinghub.elsevier.com/retrieve/pii/S0263823125007372},
    doi = {10.1016/j.tws.2025.113645},
    abstract = {As space engines advance toward reusability, addressing structural fatigue fractures has become increasingly critical. The small pipelines within these engines are particularly vulnerable to damage from vibration loads, which can lead to cracks and failures, ultimately compromising engine safety. Although random vibration experiments are routinely employed to verify pipeline reliability, detailed research on quantitative fatigue life prediction methods for pipelines under complex pre-load and vibration conditions remains limited. This study investigates the mechanisms of vibration-induced fatigue failure by analyzing random vibration test results. A finite element model (FEM) was developed to simulate the vibration response of pipelines subjected to pre-loaded and heterogeneous vibration excitations. The accuracy of various time-domain and frequencydomain life assessment methods was evaluated, confirming the effectiveness of the multi-axial equivalent stress approach based on Lemaitre stress and the Dirlik frequency-domain model. Moreover, this study demonstrates that the effects of internal pressure, boundary displacement, and attached mass can be linearly superimposed to accurately predict pipeline fatigue lifetimes.},
    language = {en},
    urldate = {2026-02-03},
    journal = {Thin-Walled Structures},
    author = {Xiao, Ce and Zhang, Jinke and Han, Yichen and Du, Minglong and Li, Zhe and Li, Xionghui and Ma, Yuan and Nan, Xiangyi and Liu, Jinxin and Mao, Hongwei},
    month = nov,
    year = {2025},
    pages = {113645},
}

@article{50,
    title = {The study of the influence of load amplitude on the fatigue behavior of {Al} 7075-{T6} double-lap bolted joints},
    volume = {2951},
    issn = {1742-6596},
    url = {https://doi.org/10.1088/1742-6596/2951/1/012061},
    doi = {10.1088/1742-6596/2951/1/012061},
    abstract = {To investigate the influence of varying load amplitudes on the fatigue behavior of 7075-T6 aluminum alloy bolted joints, a series of fatigue tests and finite element analyses were conducted across a broad load range of 8 kN to 20 kN, with a constant tightening torque set at 10 N·m. The experimental results indicated no significant wear or fatigue damage was observed in the bolted joints under low load amplitudes. However, as the load amplitude increased, wear was exacerbated at the bolt joint, leading to a transition in failure mode from fretting fatigue to ordinary fatigue. Finite element analysis results revealed that stress amplitude and slip amplitude within the bolt joint increased with rising load amplitudes. Furthermore, the location of maximum stress shifted from the periphery of the hole towards its edge. This shift elucidated why failure modes in bolt joints transition from fretting fatigue to ordinary fatigue as loading conditions change.},
    language = {en},
    number = {1},
    urldate = {2026-02-04},
    journal = {Journal of Physics: Conference Series},
    publisher = {IOP Publishing},
    author = {Li, Ben and Zhang, Mingyuan and Huang, Yuanzhe and Li, Yingjun and Cui, Yuheng},
    month = feb,
    year = {2025},
    pages = {012061},
}

